7. EventProcessingState (for BotSM)

// Add this state to your state machine

public class EventProcessingState extends BotState {

    @Override
    public void execute(BotSM bot) { // [x]
        // Process all queued events
        bot.processQueuedEvents();

        // Transition logic
        if (bot.hasQueuedEvents()) {
            // Stay in this state if more events to process
            return;
        } else {
            // Move to next appropriate state
            bot.setState(new IdleState()); // or whatever your next state is
        }
    }

    @Override
    public boolean shouldInterrupt(BotSM bot) { //[no need]
        // Check if we should interrupt current state for event processing
        return bot.hasQueuedEvents() && bot.getCurrentState() != this;
    }
}

