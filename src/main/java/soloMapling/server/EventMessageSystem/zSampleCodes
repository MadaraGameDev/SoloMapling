8. Example Subscription Code

// Example: GachaBot subscribing to gachapon events
public class GachaBot extends BotSM {

    public void initialize() { //[x]
        // Subscribe to gachapon events
        EventBus.getInstance().subscribe(EventType.GACHAPON_REWARD, this);

        // Could also subscribe to multiple types
        EventBus.getInstance().subscribe(EventType.ITEM_MEGAPHONE, this);
    }

    public void shutdown() {
        // Unsubscribe when shutting down
        EventBus.getInstance().unsubscribe(EventType.GACHAPON_REWARD, this);
        EventBus.getInstance().unsubscribe(EventType.ITEM_MEGAPHONE, this);
    }
}

// Example: Publishing an event
public void onGachaponRare(MapleCharacter player, Item item, MapleMap map) {
    GameEvent event = EventFactory.createGachaponEvent(
        player.getWorld(),
        player.getChannel(),
        map,
        player.getName(),
        player.getId(),
        item
    );
    EventBus.getInstance().publish(event);
}