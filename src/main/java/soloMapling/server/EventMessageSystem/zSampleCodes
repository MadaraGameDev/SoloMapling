5. Bot EventSubscriber Implementation (for BotSM)

// Add these to your BotSM class

public class BotSM implements EventSubscriber { //[x]
    private final BotEventBuffer eventBuffer;
    private final Integer targetWorld;
    private final Integer targetChannel;
    private final Integer targetMapId;

    public BotSM() { //[x]
        this.eventBuffer = new BotEventBuffer(100); // Max 100 queued events
        // Set these based on your bot's location
        this.targetWorld = null; // null means accept all worlds
        this.targetChannel = null;
        this.targetMapId = null;
    }

    @Override
    public void onEvent(GameEvent event) { //[x]
        // Queue the event for processing later
        eventBuffer.add(event);
    }

    @Override
    public boolean matchesFilter(GameEvent event) { //[x]
        // Check if this event is relevant to this bot
        if (targetWorld != null && event.getWorld() != targetWorld) {
            return false;
        }
        if (targetChannel != null && event.getChannel() != targetChannel) {
            return false;
        }
        if (targetMapId != null && event.getMap().getId() != targetMapId) {
            return false;
        }
        return true;
    }

    // Call this from your event processing state
    public void processQueuedEvents() { //[x]
        GameEvent event;
        while ((event = eventBuffer.poll()) != null) {
            handleEvent(event);
        }
    }

    private void handleEvent(GameEvent event) { //[x]
        // Process based on event type
        switch (event.getType()) {
            case GACHAPON_REWARD:
                handleGachaponEvent(event);
                break;
            case UPGRADE_RESULT:
                handleUpgradeEvent(event);
                break;
            // Add other cases as needed
        }
    }

    public boolean hasQueuedEvents() { //[x]
        return !eventBuffer.isEmpty();
    }
}

